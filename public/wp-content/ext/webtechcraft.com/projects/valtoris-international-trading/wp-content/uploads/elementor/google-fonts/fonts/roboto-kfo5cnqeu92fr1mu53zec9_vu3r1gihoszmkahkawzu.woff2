html {
  scroll-behavior: smooth;
}
.gradient {
  --size: 750px;
  --speed: 50s;
  --easing: cubic-bezier(0.8, 0.2, 0.2, 0.8);

  width: 400px;
  height: 400px;
  filter: blur(calc(var(10px) / 5));
  background-image: linear-gradient(hsl(222, 84, 60, 100%), hsl(164, 79, 71));
  animation: rotate var(--speed) var(--easing) alternate infinite;
  border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
}

.portfolio-item .portfolio-images {
    opacity: 0;
}
/* Styling for the ball */
.mouse-ball {
    position: fixed;
    top: 0;
    left: 0;
    width: 10px;
    height: 10px;
    background-color: #2d00d3;
    border-radius: 50%;
    pointer-events: none;
    transition: transform 0.2s ease, width 0.2s ease, height 0.2s ease;
    z-index: 99999;
}

/* Increase size on hover */
.mouse-ball.hover {
    transform: scale(6); /* Scales the ball to 2x size */
    background-color: #2d00d321; /* Optional: change color */
}

.portfolio-item.active .portfolio-images {
    animation: fadeIn 0.90s linear forwards; /* Apply the animation */
}

@keyframes fadeIn {
    0% {
        opacity: 0;
    }
    100% {
        opacity: 1;
    }
}
.tab-pane .price-box {
	opacity: 0;
}
.tab-pane.active .price-box {
    animation: fadeIn 0.90s linear forwards; /* Apply the animation */
}

