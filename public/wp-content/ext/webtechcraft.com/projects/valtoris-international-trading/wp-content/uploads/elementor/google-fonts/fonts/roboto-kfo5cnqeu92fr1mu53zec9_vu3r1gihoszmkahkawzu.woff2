    <style>
button.plyr__control { color: #fff;
    border-color: #fff;}

button.plyr__control:focus {  
    background-color: #2D00D3;
}
button.plyr__control:hover { 
background-color: #2D00D3 !important;
 }
a.website-design {
    height: 650px;
    position: relative;
    overflow: hidden;
}
a.website-design img {
 
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: all 2s ease-in-out;
 
}
a.ecommerce img {
 
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: all 2s ease-in-out;
 
}
a.website-design:hover img {
    object-position: bottom;
}
a.ecommerce:hover img {
    object-position: bottom;
}
.portfolio-tabs {
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: 20px;
}

a.portfolio-tab {
   cursor: pointer;
   font-family: "Biennale Medium", Sans-serif;
    border-radius: 34px;
    background-color: #fff;
    border: 1.6px solid #0F0928;
    font-size: 16px;
    color: #2d00d3 !important;
    padding: 10px 30px;
    font-weight: 600;
    box-shadow: 0 7px 42px 0 rgba(49, 49, 49, 0.01);
    text-align: center;
}
 
a.portfolio-tab.active {
    color: #fff;
    background-color: #2d00d3;
    border: 1.6px solid #2d00d3;
    font-size: 16px;
    color: #fff !important;
    box-shadow: 0 7px 42px 0 rgba(49, 49, 49, 0.01);
 
}
 
a.portfolio-tab:hover {
    color: #fff;
    background-color: #2d00d3;
    border: 1.6px solid #2d00d3;
    font-size: 16px;
    color: #fff !important;
    box-shadow: 0 7px 42px 0 rgba(49, 49, 49, 0.01);
}
 
.portfolio-item {
    margin-top: 60px;
}

.portfolio-images {
    display: flex;
    flex-wrap: wrap;
    border-left: 1px solid #0F0928;
    border-right: 1px solid #0F0928;
    border-top: 1px solid #0F0928;
}
.portfolio-images a {
    flex-grow: unset;
    width: 33.33%;
    padding: 50px 40px;
    border-bottom: 1px solid #0F0928;
    border-right: 1px solid #0F0928;
}
.portfolio-images a:nth-child(3n+3) {
    border-right: none;
}

a.ecommerce {
    height: 650px;
    position: relative;
    overflow: hidden;
}
a.website-design {
    height: 650px;
    position: relative;
    overflow: hidden;
}
</style>
 <script>
    document.addEventListener('DOMContentLoaded', function () {
        // Select elements
        const content = document.getElementById('content');
        const pageContent = document.querySelector('.page-content');
        const portfolioImages = document.querySelectorAll('.portfolio-images a');

        let lastScrollY = window.scrollY;  // Track last scroll position
        let velocity = 0;  // Scroll velocity
        let skewValue = 0;  // Skew effect value

        // Smooth scrolling (using native JS)
        let smoothScroll = () => {
            const scrollTop = window.scrollY;
            const scrollSpeed = scrollTop - lastScrollY;
            velocity = Math.abs(scrollSpeed);  // Calculate velocity

            // Update the skew effect based on velocity
            skewValue = Math.min(Math.max(-15, -velocity / 10), 15);  // Clamp skew value

            // Apply skew effect to portfolio images
            portfolioImages.forEach(image => {
                image.style.transform = `skewY(${skewValue}deg)`;  // Apply skew effect
            });

            // Update last scroll position
            lastScrollY = scrollTop;

            // Use requestAnimationFrame for smooth scrolling
            requestAnimationFrame(smoothScroll);
        };

        // Start smooth scrolling
        smoothScroll();

        // Add smooth scroll behavior to the page content
        pageContent.style.scrollBehavior = 'smooth';

        // Adjust content scroll position based on window scroll
        window.addEventListener('scroll', () => {
            // Optional: You can add additional logic to handle scroll position if needed
        });
    });
</script>
 
<script>
document.addEventListener("DOMContentLoaded", function () {
 

    // Filter portfolio items based on selected category
    function filterPortfolioItems(category) {
        console.log("Selected category:", category);

        // Remove active class from all tabs and add it to the clicked tab
        document.querySelectorAll(".portfolio-tab").forEach(function (tab) {
            tab.classList.remove("active");
        });
        document.querySelector('.portfolio-tab[data-category="' + category + '"]').classList.add("active");

        // Hide all portfolio items
        document.querySelectorAll(".portfolio-item").forEach(function (item) {
            item.style.display = "none";
            item.classList.remove("active");
        });

        // Show the items that match the selected category
        document.querySelectorAll('.portfolio-item[data-categories="' + category + '"]').forEach(function (item) {
            item.style.display = "block";
            item.classList.add("active");
        });
    }

    // On tab click, filter portfolio items
    document.querySelectorAll(".portfolio-tab").forEach(function (tab) {
        tab.addEventListener("click", function () {
            var category = this.getAttribute("data-category");
            filterPortfolioItems(category);
        });
    });

    // Display the first tab content on window load
    var firstTab = document.querySelector(".portfolio-tab:first-of-type");
    if (firstTab) {
        var firstCategory = firstTab.getAttribute("data-category");
        firstTab.classList.add("active"); // Set the first tab as active
        filterPortfolioItems(firstCategory); // Show the first category's items
    }
});
</script>


 

