   <script>
		 document.addEventListener("DOMContentLoaded", () => {
    const mouseBall = document.querySelector(".mouse-ball");

    // Update ball position
    document.addEventListener("mousemove", (e) => {
        mouseBall.style.top = `${e.clientY}px`;
        mouseBall.style.left = `${e.clientX}px`;
    });

    // Add hover effect for <a> tags
    document.querySelectorAll("a").forEach((link) => {
        link.addEventListener("mouseenter", () => {
            mouseBall.classList.add("hover");
        });

        link.addEventListener("mouseleave", () => {
            mouseBall.classList.remove("hover");
        });
    });
});

const sr = ScrollReveal({
    origin: 'bottom',
    distance: '05px',
