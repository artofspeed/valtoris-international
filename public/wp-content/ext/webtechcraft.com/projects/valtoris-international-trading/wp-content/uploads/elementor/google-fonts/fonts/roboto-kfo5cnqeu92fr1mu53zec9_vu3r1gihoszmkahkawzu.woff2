.button--bubble:hover {
	color: #fff;
  
}
.chat-b a.button.button--bubble.popup-open {
	    box-shadow: 2px 2px 8px #2d00d32b, 2px 2px 38px #3600ff7a;
    padding-right: 120px;
    background-image: url(https://webtechcraft.com/wp-content/uploads/2024/12/Group-485-1.png);
    background-repeat: no-repeat;
    background-size: 37%;
    background-position-x: 155px;
    background-position-y: center;
}
.button--bubble{
    font-family: "Biennale", Sans-serif;
    text-transform: uppercase;
    border-radius: 34px;
    background-color: #2d00d3;
    border: 1px solid #2d00d3;
    font-size: 16px;
    color: #fff;
    display: inline-block;
    padding: 10px 30px;
    position: relative;
    z-index: 222;
    box-shadow: 0 7px 42px 0 rgba(49, 49, 49, 0.01);
	  width: 100% !important;
    text-align: center;
}
.button--bubble__effect-container {
    position: absolute;
    display: block;
    width: 200%;
    height: 400%;
    top: -150%;
    left: -50%;
    -webkit-filter: url(#goo);
    filter: url(#goo);
    transition: all 0.1s ease-out;
    pointer-events: none;
}
.button--bubble__effect-container .circle.top-left {
    top: 40%;
    left: 27%;
}
.button--bubble__effect-container .circle {
    position: absolute;
    width: 25px;
    height: 25px;
    border-radius: 15px;
    background: #2d00d3;
    transition: background 0.1s ease-out;
}
.button--bubble__effect-container .circle.top-left {
    top: 40%;
    left: 27%;
}
.button--bubble__container .effect-button {
    position: absolute;
    width: 50%;
    height: 25%;
    top: 50%;
    left: 25%;
    z-index: 1;
    -webkit-transform: translateY(-50%);
    transform: translateY(-50%);
    background: #2d00d3;
    transition: background 0.1s ease-out;
     border-radius: 34px;
}
.button--bubble__effect-container .circle.bottom-right {
    bottom: 40%;
    right: 27%;
}
.p-button a.button.button--bubble.popup-open {
    border-radius: 5px;
    font-size: 14px;
    padding: 9px 30px;
}

.p-button span.button.effect-button {
    height: 23%;
}
