sr.reveal('.my-animationfour', {interval: 200} )
sr.reveal('.my-animationfive', {interval: 200} )
  </script>
<script>
    function myFunction(x) {
        console.log('Function triggered');
        x.classList.toggle("change");

        if (typeof elementorProFrontend !== 'undefined' && elementorProFrontend.modules.popup) {
            console.log('Popup module found');
            const popupId = 366; // Replace with your actual popup ID
            const popup = elementorProFrontend.modules.popup;

            // Check if the popup is open by looking at its state
            const isPopupOpen = document.querySelector(`.elementor-popup[data-id="${popupId}"]`)?.classList.contains('elementor-open');

            if (isPopupOpen) {
                console.log('Popup is open, closing now');
                popup.closePopup({ id: popupId });
            } else {
                console.log('Popup is closed, opening now');
                popup.showPopup({ id: popupId });
            }
        } else {
            console.error('Elementor Pro Popup module is not loaded.');
        }
    }
</script>

<script>
    function openLiveChat() {
        if (typeof Tawk_API !== "undefined") {
            Tawk_API.toggle(); // Opens or closes the chat window
        } else {
            console.log("Tawk.to API not found.");
        }
    }


</script>
